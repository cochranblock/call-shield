<?xml version="1.0" encoding="utf-8"?>
<!--
    Call Shield network security config.
    No cleartext. No network. This file exists to make the absence explicit.
    The app has no INTERNET permission — this is defense in depth.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
